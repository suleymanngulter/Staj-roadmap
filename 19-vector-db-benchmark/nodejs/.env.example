# ChromaDB (docker compose: port 8000)
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
CHROMA_SEARCH_EF=300
CHROMA_PROBE_EF=100

# PostgreSQL + pgvector
PG_DSN=postgresql://postgres:postgres@127.0.0.1:5433/vector_bench
PG_HNSW_M=16
PG_HNSW_EF=64
PG_HNSW_EF_SEARCH=100

# MongoDB Atlas Vector Search
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB=vector_bench
MONGODB_COLL=embeddings
MONGODB_INDEX=vector_index
MONGODB_NUM_CANDIDATES=100
MONGODB_TIER=M0
MONGODB_AUTO_EMBED=1
MONGODB_TEXT_FIELD=text
MONGODB_EMBED_MODEL=voyage-4-lite
MONGODB_AUTO_EMBED_N_QUERIES=10
# Ücretsiz Voyage (3 RPM): sorgular ARASI bekleme — query med'ye dahil edilmez
MONGODB_EMBED_QUERY_DELAY_MS=21000

# Pinecone
PINECONE_API_KEY=your-api-key
PINECONE_INDEX=vector-bench-384
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_RECREATE_INDEX=0

# Benchmark
QUERY_RUNS=3
MULTI_RUNS=1
PG_HNSW_EF_SEARCH=300
PG_FORCE_HNSW=1
